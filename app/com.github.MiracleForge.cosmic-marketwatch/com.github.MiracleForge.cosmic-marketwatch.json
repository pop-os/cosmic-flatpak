{
  "$schema": "https://raw.githubusercontent.com/flatpak/flatpak-builder/main/data/flatpak-manifest.schema.json",
  "id": "com.github.MiracleForge.cosmic-marketwatch",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "24.08",

  "base": "com.system76.Cosmic.BaseApp",
  "base-version": "stable",

  "sdk": "org.freedesktop.Sdk",

"sdk-extensions": [
  "org.freedesktop.Sdk.Extension.rust-nightly"
  ],

  "command": "cosmic-marketwatch",

  "finish-args": [
    "--share=ipc",
    "--socket=wayland",
    "--socket=fallback-x11",
    "--device=dri",

    "--share=network",

    "--talk-name=com.system76.CosmicSettingsDaemon",

    "--filesystem=xdg-config/cosmic:rw"
  ],

"build-options": {
  "append-path": "/usr/lib/sdk/rust-nightly/bin",
  "env": {
    "CARGO_HOME": "/run/build/cosmic-marketwatch/cargo"
  }
},

  "modules": [
    {
      "name": "cosmic-marketwatch",
      "buildsystem": "simple",

      "build-commands": [

        "cargo --offline fetch --manifest-path Cargo.toml",
        "cargo --offline build --release",

        "install -Dm755 target/release/cosmic-marketwatch /app/bin/cosmic-marketwatch",

        "install -Dm644 flatpak/com.github.MiracleForge.cosmic-marketwatch.desktop /app/share/applications/com.github.MiracleForge.cosmic-marketwatch.desktop",
        "install -Dm644 resources/app.metainfo.xml /app/share/metainfo/com.github.MiracleForge.cosmic-marketwatch.metainfo.xml",


        "install -Dm644 resources/icons/hicolor/scalable/apps/com.github.MiracleForge.cosmic-marketwatch.svg /app/share/icons/hicolor/scalable/apps/com.github.MiracleForge.cosmic-marketwatch.svg",
        "install -Dm644 resources/icons/hicolor/scalable/apps/com.github.MiracleForge.cosmic-marketwatch-panel.svg /app/share/icons/hicolor/scalable/apps/com.github.MiracleForge.cosmic-marketwatch-panel.svg"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/MiracleForge/cosmic-marketwatch.git",
          "tag": "1.0.1"
        },
       "cargo-sources.json"
      ]
    }
  ]
}
