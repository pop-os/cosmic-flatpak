{
    "id": "com.github.sreevikramr.singularity",
    "runtime": "org.freedesktop.Platform",
    "runtime-version": "25.08",
    "sdk": "org.freedesktop.Sdk",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.rust-stable",
        "org.freedesktop.Sdk.Extension.llvm20"
    ],
    "base": "com.system76.Cosmic.BaseApp",
    "base-version": "stable",
    "command": "singularity",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--share=network",
        "--system-talk-name=org.bluez",
        "--system-talk-name=org.freedesktop.NetworkManager",
        "--system-talk-name=org.freedesktop.UPower",
        "--system-talk-name=org.freedesktop.login1",
        "--talk-name=org.freedesktop.Notifications",
        "--talk-name=org.mpris.MediaPlayer2.*",
        "--talk-name=org.freedesktop.DBus",
        "--own-name=org.mpris.MediaPlayer2.singularity",
        "--talk-name=com.system76.CosmicSettingsDaemon",
        "--filesystem=xdg-config/cosmic:rw"
    ],
    "build-options": {
        "append-path": "/usr/lib/sdk/rust-stable/bin:/usr/lib/sdk/llvm20/bin",
        "env": {
            "CARGO_HOME": "/run/build/singularity/cargo",
            "LIBCLANG_PATH": "/usr/lib/sdk/llvm20/lib"
        }
    },
    "modules": [
        {
            "name": "singularity",
            "buildsystem": "simple",
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/sreevikramr/singularity.git",
                    "branch": "main"
                },
                "cargo-sources.json"
            ],
            "build-commands": [
                "cargo build --release --offline",
                "install -Dm0755 target/release/singularity /app/bin/singularity",
                "install -Dm0644 resources/app.desktop /app/share/applications/com.github.sreevikramr.singularity.desktop",
                "install -Dm0644 resources/app.metainfo.xml /app/share/metainfo/com.github.sreevikramr.singularity.metainfo.xml",
                "install -Dm0644 resources/icon.svg /app/share/icons/hicolor/scalable/apps/com.github.sreevikramr.singularity.svg"
            ]
        }
    ]
}
