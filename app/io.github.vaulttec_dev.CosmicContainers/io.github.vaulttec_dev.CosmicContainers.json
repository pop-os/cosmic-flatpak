{
  "id": "io.github.vaulttec_dev.CosmicContainers",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "25.08",
  "sdk": "org.freedesktop.Sdk",
  "sdk-extensions": ["org.freedesktop.Sdk.Extension.rust-stable"],
  "base": "com.system76.Cosmic.BaseApp",
  "base-version": "stable",
  "command": "linux-pop-extension",
  "finish-args": [
    "--socket=wayland",
    "--share=ipc",
    "--device=dri",
    "--talk-name=com.system76.CosmicSettingsDaemon",
    "--talk-name=org.freedesktop.Flatpak",
    "--filesystem=xdg-config/cosmic:rw",
    "--filesystem=xdg-config/linux-pop-extension:rw",
    "--filesystem=xdg-config/io.github.vaulttec_dev.CosmicContainers:rw",
    "--filesystem=/var/run/docker.sock"
  ],
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin",
    "env": {
      "CARGO_HOME": "/run/build/linux-pop-extension/cargo"
    }
  },
  "modules": [
    {
      "name": "linux-pop-extension",
      "buildsystem": "simple",
      "build-commands": [
        "cargo --offline fetch --manifest-path Cargo.toml --verbose",
        "cargo --offline build --release --features applet --verbose",
        "install -Dm0755 target/release/linux-pop-extension /app/bin/linux-pop-extension",
        "install -Dm0644 resources/io.github.vaulttec_dev.CosmicContainers.desktop /app/share/applications/io.github.vaulttec_dev.CosmicContainers.desktop",
        "install -Dm0644 resources/io.github.vaulttec_dev.CosmicContainers.metainfo.xml /app/share/metainfo/io.github.vaulttec_dev.CosmicContainers.metainfo.xml",
        "install -Dm0644 resources/icons/hicolor/scalable/apps/io.github.vaulttec_dev.CosmicContainers.svg /app/share/icons/hicolor/scalable/apps/io.github.vaulttec_dev.CosmicContainers.svg"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/vaulttec-dev/linux-pop-extension.git",
          "tag": "v0.1.0",
          "commit": "c61f1400902de089f6cd9b9cfc01a0cc4505bf35"
        },
        "cargo-sources.json"
      ]
    }
  ]
}
